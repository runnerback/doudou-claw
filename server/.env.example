NODE_ENV=development
PORT=13100

# 飞书开放平台凭证（从 https://open.feishu.cn → 应用详情 → 凭证 获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 是否启动 bot 长连接（同一个 App 只能一处连，多端同时连会消息重复）
# 本地: false（默认） | 临时调试: true | ECS: true
ENABLE_BOT=false

# DeepSeek 大模型
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_BASE=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 任务清单 - 飞书多维表格
REMINDER_BITABLE_APP_TOKEN=xxx
REMINDER_BITABLE_TABLE_ID=tblxxx

# 调度时区
SCHEDULE_TZ=Asia/Shanghai

# 早安总结天气城市（wttr.in 城市名）
MORNING_WEATHER_CITY=Shanghai
